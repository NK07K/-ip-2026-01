2- Arrecadação de Jogos 

 

programa { 

  funcao inicio() { 

    // Declaração de variáveis 

    inteiro quantidadeJogos, i 

    real valorJogo, arrecadacaoTotal = 0.0, valorMaior = 0.0 

    cadeia nomeJogo, jogoMaisCaro = "" 

 

    escreva("Quantos jogos foram arrecadados? ") 

    leia(quantidadeJogos) 

 

    // Limpa o buffer do teclado se necessário 

     

    // Estrutura de repetição para cadastrar os jogos 

    para(i = 1; i <= quantidadeJogos; i++) 

    { 

      escreva("\n--- Jogo ", i, " ---\n") 

      escreva("Nome do jogo: ") 

      leia(nomeJogo) 

      escreva("Valor estimado do jogo: R$ ") 

      leia(valorJogo) 

 

      // Acumula o valor total 

      arrecadacaoTotal = arrecadacaoTotal + valorJogo 

 

      // Verifica qual é o jogo mais caro 

      se(valorJogo > valorMaior) 

      { 

        valorMaior = valorJogo 

        jogoMaisCaro = nomeJogo 

      } 

    } 

 

    // Exibe os resultados 

    escreva("\n==============================") 

    escreva("\nTotal de jogos arrecadados: ", quantidadeJogos) 

    escreva("\nArrecadação Total: R$ ", arrecadacaoTotal) 

    escreva("\nJogo mais caro: ", jogoMaisCaro, " (R$ ", valorMaior, ")") 

    escreva("\n==============================\n") 

  } 

  } 

 

 

 

3- Composição Inteira  

programa { 

  funcao inicio() { 

    inteiro n1, n2, n3, numero, quadrado 

 

    // 1. Leitura dos dados 

    escreva("Digite o primeiro dígito (n1): ") 

    leia(n1) 

    escreva("Digite o segundo dígito (n2): ") 

    leia(n2) 

    escreva("Digite o terceiro dígito (n3): ") 

    leia(n3) 

 

    // 2. Validação dos dígitos 

    se (n1 < 0 ou n1 > 9 ou n2 < 0 ou n2 > 9 ou n3 < 0 ou n3 > 9) { 

      escreva("DIGITO INVALIDO") 

    } senao { 

      // 3. Cálculo da concatenação e do quadrado 

      numero = (n1 * 100) + (n2 * 10) + n3 

      quadrado = numero * numero 

 

      // 4. Exibição dos resultados 

      escreva("Número calculado: ", numero) 

      escreva("\nQuadrado do número: ", quadrado) 

    } 

  } 

} 

 

 

 

 

 

 

 

 

 

 

 

 

