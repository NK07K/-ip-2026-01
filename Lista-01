8- Custo da lata de cerveja 

programa 

{ 

    funcao inicio() 

    { 

        real raio 

        real altura 

        real area_circulo 

        real area_lateral 

        real area_total 

        real custo 

        real pi 

 

        pi = 3.14159 

 

        escreva("Qual valor do raio? ") 

        leia(raio) 

        escreva("Qual valor da altura? ") 

        leia(altura) 

 

        area_circulo = pi * raio * raio 

        area_lateral = 2 * pi * raio * altura 

        area_total = 2 * area_circulo + area_lateral 

 

        custo = area_total * 100 

 

        escreva("O VALOR DO CUSTO E = ", custo, "\n") 

    } 

} 

 

 

 

 

 

 

 

 

 

 

 

